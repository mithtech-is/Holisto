{
  "name": "@holisto/medusa-plugin-cashfree-wallet",
  "version": "0.1.0",
  "description": "Holisto — Cashfree-backed custodial INR wallet for Medusa v2: virtual accounts (VBA) auto-collect deposits, Secure ID KYC (PAN/Aadhaar/Bank/Demat), held-order auto-capture, promo balance, and an admin wallet console.",
  "license": "UNLICENSED",
  "keywords": [
    "medusa",
    "medusa-v2",
    "medusa-plugin",
    "medusa-plugin-integration",
    "medusa-plugin-payment",
    "cashfree",
    "wallet",
    "virtual-account",
    "vba",
    "kyc",
    "secure-id",
    "india",
    "inr"
  ],
  "files": [
    ".medusa/server",
    "package.json",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "medusa plugin:build",
    "develop": "medusa plugin:develop",
    "typecheck": "tsc --noEmit",
    "pack:local": "npm pack"
  },
  "exports": {
    "./package.json": "./package.json",
    "./workflows": "./.medusa/server/src/workflows/index.js",
    "./.medusa/server/src/modules/*": "./.medusa/server/src/modules/*/index.js",
    "./modules/*": "./.medusa/server/src/modules/*/index.js",
    "./providers/*": "./.medusa/server/src/providers/*/index.js",
    "./admin": {
      "import": "./.medusa/server/src/admin/index.mjs",
      "require": "./.medusa/server/src/admin/index.js",
      "default": "./.medusa/server/src/admin/index.js"
    },
    "./*": "./.medusa/server/src/*.js"
  },
  "dependencies": {
    "express-rate-limit": "^7.1.5",
    "multer": "^1.4.5-lts.1",
    "pdf-parse": "^1.1.4",
    "sharp": "^0.33.5",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@medusajs/admin-sdk": "^2.15.5",
    "@medusajs/cli": "^2.15.5",
    "@medusajs/framework": "^2.15.5",
    "@medusajs/icons": "^2.15.5",
    "@medusajs/medusa": "^2.15.5",
    "@medusajs/ui": "^4.1.15",
    "@swc/core": "^1.5.7",
    "@types/node": "^20.11.30",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.2.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5"
  },
  "peerDependencies": {
    "@medusajs/admin-sdk": "^2.15.5",
    "@medusajs/cli": "^2.15.5",
    "@medusajs/framework": "^2.15.5",
    "@medusajs/icons": "^2.15.5",
    "@medusajs/medusa": "^2.15.5",
    "@medusajs/ui": "^4.1.15",
    "react": ">=18",
    "react-dom": ">=18",
    "typescript": ">=5"
  }
}
