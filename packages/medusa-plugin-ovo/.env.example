# OVO plugin environment variables.
# All credentials can also be set (encrypted) from the admin UI; env is a fallback.

# Demo mode — production MUST be false. true seeds generic "Acme" example data.
OVO_DEMO_MODE=false

# REQUIRED in production: 32+ random chars used to encrypt stored credentials.
OVO_ENCRYPTION_KEY=

# Your public storefront URL — used for audits, sitemap discovery, URL inspection.
OVO_SITE_URL=

# Google Search Console
OVO_GSC_SERVICE_ACCOUNT_JSON=
OVO_GSC_PROPERTY=

# Bing Webmaster
OVO_BING_API_KEY=
OVO_BING_SITE_URL=

# IndexNow (notifies Bing + Yandex)
OVO_INDEXNOW_KEY=

# AI providers (any subset)
OVO_OPENAI_API_KEY=
OVO_ANTHROPIC_API_KEY=
OVO_PERPLEXITY_API_KEY=
OVO_GEMINI_API_KEY=

# Optional
OVO_ENABLE_JOBS=true
OVO_STOREFRONT_REVALIDATE_URL=
OVO_REVALIDATE_SECRET=
OVO_ALT_SUGGEST_HOSTS=
