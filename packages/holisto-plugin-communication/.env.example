# =====================================================================
# Medusa Plugin Communication — Environment Variables
# =====================================================================
# Copy this file to .env and fill in your values.
# All provider credentials are encrypted at rest using AES-256-GCM.
# =====================================================================

# --- Required: Encryption ---
# Used to encrypt provider API keys and secrets at rest in the database.
# Must be at least 16 characters long.
COMMUNICATION_ENCRYPTION_SECRET=change-me-to-a-random-32-char-string
# Alternative variable name (fallback):
# COMM_ENCRYPTION_SECRET=

# --- Email Provider (SMTP) ---
# Configured via the admin UI. Environment variable overrides:
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=your@email.com
# SMTP_PASS=your-password
# SMTP_FROM=noreply@example.com
# SMTP_FROM_NAME=My Store
# SMTP_SECURITY=tls

# --- MSG91 SMS ---
# Configured via the admin UI.
# MSG91_AUTH_KEY=your-msg91-auth-key
# MSG91_SENDER_ID=COMM
# MSG91_DEFAULT_TEMPLATE_ID=
# MSG91_OTP_TEMPLATE_ID=

# --- Polygin WhatsApp ---
# Configured via the admin UI.
# POLYGIN_API_TOKEN=your-polygin-api-token
# POLYGIN_DASHBOARD_JWT=your-polygin-dashboard-jwt
# POLYGIN_SENDER_PHONE=+919999999999

# --- OTP Options ---
# OTP_TTL_SECONDS=300
# OTP_MAX_ATTEMPTS=5
# OTP_RESEND_COOLDOWN_SECONDS=60
# OTP_DEFAULT_CHANNEL=whatsapp
# OTP_FALLBACK_CHANNEL=sms

# --- Plugin Options (for medusa-config.js) ---
