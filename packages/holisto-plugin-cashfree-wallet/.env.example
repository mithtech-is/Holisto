# Cashfree Wallet plugin environment variables.
#
# Cashfree API credentials are normally configured (encrypted) from the
# admin "Cashfree" settings page and stored in the `cashfree_setting` row.
# The env vars below are a FALLBACK used when no DB credential is present.

# ── REQUIRED: at-rest encryption key ────────────────────────────────────
# 32-byte key, base64-encoded (preferred), OR a >=32-char passphrase
# (legacy, derived via scrypt). Encrypts Cashfree secrets + bank account
# numbers + (after the PII-encryption migration) PAN/Aadhaar/CMR registries.
# LOSING THIS KEY MAKES STORED SECRETS + PII UNREADABLE. Back it up.
AT_REST_ENCRYPTION_KEY=

# ── Cashfree credential fallbacks (prefer the admin UI) ─────────────────
CASHFREE_ENV=sandbox
CASHFREE_CLIENT_ID=
CASHFREE_CLIENT_SECRET=
CASHFREE_PAYOUTS_CLIENT_ID=
CASHFREE_PAYOUTS_CLIENT_SECRET=
CASHFREE_WEBHOOK_SECRET=
CASHFREE_VERIFY_WEBHOOK_SECRET=

# ── Branding / VBA defaults (override the hardcoded "POLEMARCH") ─────────
# Default beneficiary name shown to remitters on their bank transfer
# screen when no per-customer PAN-verified name applies.
CASHFREE_VBA_PREFIX=

# NODE_ENV gates production strictness on the encryption key.
# NODE_ENV=production
