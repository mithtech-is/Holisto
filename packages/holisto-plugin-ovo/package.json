{
  "name": "@holisto/holisto-plugin-ovo",
  "version": "0.1.0",
  "description": "Holisto — OVO (Online Visibility Optimization) plugin for Medusa",
  "license": "UNLICENSED",
  "keywords": [
    "medusa",
    "medusa-v2",
    "medusa-plugin",
    "medusa-plugin-integration",
    "medusa-plugin-analytics",
    "seo",
    "ai-visibility",
    "geo",
    "aeo",
    "llmo",
    "indexnow",
    "search-console",
    "bing-webmaster"
  ],
  "files": [
    ".medusa/server",
    "package.json",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "medusa plugin:build",
    "develop": "medusa plugin:develop",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "pack:local": "npm pack"
  },
  "exports": {
    "./package.json": "./package.json",
    "./workflows": "./.medusa/server/src/workflows/index.js",
    "./.medusa/server/src/modules/*": "./.medusa/server/src/modules/*/index.js",
    "./modules/*": "./.medusa/server/src/modules/*/index.js",
    "./providers/*": "./.medusa/server/src/providers/*/index.js",
    "./admin": {
      "import": "./.medusa/server/src/admin/index.mjs",
      "require": "./.medusa/server/src/admin/index.js",
      "default": "./.medusa/server/src/admin/index.js"
    },
    "./*": "./.medusa/server/src/*.js"
  },
  "devDependencies": {
    "@medusajs/admin-sdk": "^2.14.2",
    "@medusajs/cli": "^2.14.2",
    "@medusajs/framework": "^2.14.2",
    "@medusajs/icons": "^2.14.2",
    "@medusajs/medusa": "^2.15.5",
    "@medusajs/ui": "^4.0.4",
    "@swc/core": "^1.5.7",
    "@types/node": "^20.11.30",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.2.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5",
    "vitest": "^1.6.0",
    "zod": "^3.22.0"
  },
  "peerDependencies": {
    "@medusajs/admin-sdk": "^2.14.2",
    "@medusajs/cli": "^2.14.2",
    "@medusajs/framework": "^2.14.2",
    "@medusajs/icons": "^2.14.2",
    "@medusajs/medusa": "^2.14.2",
    "@medusajs/ui": "^4.0.4",
    "react": ">=18",
    "react-dom": ">=18",
    "typescript": ">=5"
  }
}
